{
  "name": "santo/business-registry",
  "description": "Professional business management system for gyms, salons, and service-based businesses",
  "type": "project",
  "license": "proprietary",
  "authors": [
    {
      "name": "Santo",
      "email": "your-email@example.com"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "config/loader.php",
      "bootstrap.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "stan": "phpstan analyse src --level max",
    "lint": "phpcs --standard=PSR12 src",
    "lint-fix": "phpcbf --standard=PSR12 src"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
