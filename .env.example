# Application Environment
APP_ENV=production
APP_DEBUG=false
APP_NAME="BusinessRegistry"

# Database Configuration
DB_HOST=database-santo
DB_PORT=3306
DB_NAME=mio_database
DB_USER=root
DB_PASSWORD=your_secure_password_here

# Logging
LOG_LEVEL=error
LOG_CHANNEL=file

# Security
SESSION_LIFETIME=3600
CSRF_PROTECTION=true

# Mail (optional, for future use)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# Application URLs
APP_URL=http://localhost:8081
